.sidebar-nav { flex: 1 1 0%; overflow-y: auto; padding: 1rem 0px; }\n.nav-section { margin-bottom: 1.5rem; }\n.nav-section-title { font-size: 0.75rem; font-weight: 600; color: hsl(var(--muted-foreground)); text-transform: uppercase; letter-spacing: 0.05em; padding: 0px 1rem; margin-bottom: 0.5rem; }\n.nav-link { display: flex; align-items: center; gap: 0.75rem; padding: 0.625rem 1rem; color: hsl(var(--foreground)); text-decoration: none; font-size: 0.875rem; font-weight: 500; transition: 0.2s; cursor: pointer; margin: 0px 0.5rem; border-radius: 0.5rem; }\n.nav-link:hover { background: hsl(var(--secondary)); }\n.nav-link.active { background: hsl(var(--primary)); color: hsl(var(--primary-foreground)); }\n.main-content { flex: 1 1 0%; margin-left: 260px; display: flex; flex-direction: column; transition: margin-left 0.3s; }\n.sidebar.collapsed { width: 70px; }\n.sidebar.collapsed .sidebar-header { padding: 1rem 0.5rem; }\n.sidebar.collapsed .sidebar-nav { padding: 0.5rem 0px; }\n.sidebar.collapsed .nav-section { margin-bottom: 0.5rem; }\n.sidebar.collapsed .nav-link { margin: 0.25rem 0.5rem; padding: 0.75rem; justify-content: center; }\n.sidebar.collapsed + .main-content { margin-left: 70px; }\n.sidebar.collapsed .nav-link:hover::after { content: attr(title); position: absolute; left: 100%; top: 50%; transform: translateY(-50%); background: hsl(var(--popover)); color: hsl(var(--popover-foreground)); padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; white-space: nowrap; box-shadow: rgba(0, 0, 0, 0.15) 0px 4px 12px; z-index: 1000; margin-left: 0.5rem; border: 1px solid hsl(var(--border)); }\n.sidebar.collapsed .nav-link { position: relative; }\n.header { background: hsl(var(--card)); border-bottom: 1px solid hsl(var(--border)); padding: 1rem 2rem; position: sticky; top: 0px; z-index: 30; }\n.header-title { font-size: 1.5rem; font-weight: 600; color: hsl(var(--foreground)); }\n.content { flex: 1 1 0%; padding: 2rem; max-width: 1600px; width: 100%; mar