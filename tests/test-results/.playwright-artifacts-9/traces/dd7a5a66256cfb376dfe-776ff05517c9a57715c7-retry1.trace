.sidebar-nav { flex: 1 1 0%; overflow-y: auto; padding: 1rem 0px; }\n.nav-section { margin-bottom: 1.5rem; }\n.nav-section-title { font-size: 0.75rem; font-weight: 600; color: hsl(var(--muted-foreground)); text-transform: uppercase; letter-spacing: 0.05em; padding: 0px 1rem; margin-bottom: 0.5rem; }\n.nav-link { display: flex; align-items: center; gap: 0.75rem; padding: 0.625rem 1rem; color: hsl(var(--foreground)); text-decoration: none; font-size: 0.875rem; font-weight: 500; transition: 0.2s; cursor: pointer; margin: 0px 0.5rem; border-radius: 0.5rem; }\n.nav-link:hover { background: hsl(var(--secondary)); }\n.nav-link.active { background: hsl(var(--primary)); color: hsl(var(--primary-foreground)); }\n.main-content { flex: 1 1 0%; margin-left: 260px; display: flex; flex-direction: column; transition: margin-left 0.3s; }\n.sidebar.collapsed { width: 70px; }\n.sidebar.collapsed .sidebar-header { padding: 1rem 0.5rem; }\n.sidebar.collapsed .sidebar-nav { padding: 0.5rem 0px; }\n.sidebar.collapsed .nav-section { margin-bottom: 0.5rem; }\n.sidebar.collapsed .nav-link { margin: 0.25rem 0.5rem; padding: 0.75rem; justify-content: center; }\n.sidebar.collapsed + .main-content { margin-left: 70px; }\n.sidebar.collapsed .nav-link:hover::after { content: attr(title); position: absolute; left: 100%; top: 50%; transform: translateY(-50%); background: hsl(var(--popover)); color: hsl(var(--popover-foreground)); padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; white-space: nowrap; box-shadow: rgba(0, 0, 0, 0.15) 0px 4px 12px; z-index: 1000; margin-left: 0.5rem; border: 1px solid hsl(var(--border)); }\n.sidebar.collapsed .nav-link { position: relative; }\n.header { background: hsl(var(--card)); border-bottom: 1px solid hsl(var(--border)); padding: 1rem 2rem; position: sticky; top: 0px; z-index: 30; }\n.header-title { font-size: 1.5rem; font-weight: 600; color: hsl(var(--foreground)); }\n.content { flex: 1 1 0%; padding: 2rem; max-width: 1600px; width: 100%; margin: 0px auto; }\n.card { background: hsl(var(--card)); border: 1px solid hsl(var(--border)); border-radius: var(--radius); padding: 1.5rem; box-shadow: rgba(0, 0, 0, 0.1) 0px 1px 3px 0px; }\n.card-title { font-size: 1.125rem; font-weight: 600; margin-bottom: 1rem; }\n.btn { padding: 0.625rem 1.25rem; border-radius: var(--radius); font-weight: 500; font-size: 0.875rem; cursor: pointer; transition: 0.2s; border: none; display: inline-flex; align-items: center; gap: 0.5rem; text-decoration: none; }\n.btn-primary { background: hsl(var(--primary)); color: hsl(var(--primary-foreground)); }\n.btn-primary:hover { opacity: 0.9; }\n.btn-secondary { background: hsl(var(--secondary)); color: hsl(var(--secondary-foreground)); }\n.btn-secondary:hover { background: hsl(var(--muted)); }\n.table-container { overflow-x: auto; margin-top: 1rem; }\ntable { width: 100%; border-collapse: collapse; font-size: 0.875rem; }\nthead { background: hsl(var(--muted)); border-bottom: 1px solid hsl(var(--border)); }\nth { text-align: left; padding: 0.75rem 1rem; font-weight: 600; color: hsl(var(--foreground)); white-space: nowrap; }\ntd { padding: 0.75rem 1rem; border-bottom: 1px solid hsl(var(--border)); }\ntr:hover { background: hsl(var(--muted) / 0.3); }\n.form-group { margin-bottom: 1rem; }\n.form-label { display: block; font-size: 0.875rem; font-weight: 500; margin-bottom: 0.375rem; color: hsl(var(--foreground)); }\n.form-input, .form-select, .form-textarea { width: 100%; padding: 0.625rem 0.875rem; border: 1px solid hsl(var(--input)); border-radius: 0.5rem; font-size: 0.875rem; background: hsl(var(--background)); color: hsl(var(--foreground)); transition: 0.2s; }\n.form-input:focus, .form-select:focus, .form-textarea:focus { outline: none; border-color: hsl(var(--ring)); box-shadow: 0 0 0 2px hsl(var(--ring) / 0.1); }\n.form-textarea { min-height: 100px; resize: vertical; }\n.stats-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 1rem; margin-bottom: 1.5rem; }\n.stat-card { 